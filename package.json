{
  "name": "dayz-mod-setup-tool",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=24.18.0 <25",
    "npm": ">=10"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "electron-vite dev",
    "serve": "electron-vite dev",
    "build": "electron-vite build",
    "lint": "eslint --ext .js,.ts,.vue src",
    "electron:build": "npm run build && electron-builder",
    "electron:serve": "electron-vite dev",
    "postinstall": "electron-builder install-app-deps",
    "postuninstall": "electron-builder install-app-deps",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "electron:generate-icons": "electron-icon-builder --input=./public/reousrce/images/app.png --output=./public/app-icons --flatten"
  },
  "main": "out/main/background.js",
  "dependencies": {
    "@fluentui/svg-icons": "^1.1.331",
    "ant-design-vue": "^4.2.6",
    "events": "^3.3.0",
    "sqlite3": "^6.0.1",
    "stream-browserify": "^3.0.0",
    "timers-browserify": "^2.0.12",
    "vue": "3.3.0",
    "vue-class-component": "^8.0.0-0",
    "vue-i18n": "^9.2.2",
    "vue-router": "^4.0.3",
    "vuex": "^4.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^9.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-icon-builder": "^2.0.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-vue": "^8.0.3",
    "less": "^4.0.0",
    "lint-staged": "^11.1.2",
    "prettier": "^2.4.1",
    "typescript": "~5.0.3",
    "vite": "^7.3.6"
  },
  "overrides": {
    "electron-builder": "^26.15.3"
  }
}
